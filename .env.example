# RepuCare — environment variables. Copy to .env.local (NEVER commit real values).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY            # public, safe in browser
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY        # SERVER ONLY — never expose

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx          # public, safe
STRIPE_SECRET_KEY=sk_test_xxx                           # SERVER ONLY — rotate the one shared in chat!
STRIPE_WEBHOOK_SECRET=whsec_xxx                         # from `stripe listen` / dashboard webhook
STRIPE_PRICE_ID=price_xxx                               # the ₪349/mo recurring price (45-day trial)

# --- Email (optional, phase 2) ---
RESEND_API_KEY=re_xxx

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000               # prod: https://app.repucare.co.il
